# SentinelFin Environment Configuration
# Copy this file to .env and fill in your values

# AWS Bedrock Configuration (Required for LLM features)
# Get this from AWS Console → IAM → Access Keys
AWS_BEDROCK_KEY=your_base64_encoded_bedrock_key_here

# Optional: AWS region (defaults to us-east-1)
AWS_DEFAULT_REGION=us-east-1

# Optional: Override the Llama model ID
# Default: us.meta.llama3-1-70b-instruct-v1:0
BEDROCK_MODEL_ID=us.meta.llama3-1-70b-instruct-v1:0

# NOTE: If AWS_BEDROCK_KEY is not set, the system runs in FALLBACK mode:
# - Agent 3 uses a static rule-based detector (still returns risk scores)
# - Agent 6 uses a template-based SAR narrative
# The pipeline still fully completes — no crashes.
